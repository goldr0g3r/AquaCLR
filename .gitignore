# --- ML artefacts ---
# Anchored to the repo root so we don't accidentally ignore configs/data/.
# Use the "ignore contents, keep directory" idiom for /data/ so .gitkeep tracks.
/data/*
!/data/.gitkeep
!/outputs/models/
/outputs/
/logs/
/checkpoints/
/wandb/
/mlruns/
/lightning_logs/
*.ckpt
*.pt
*.pth
*.onnx
*.engine
*.plan
*.trt
*.safetensors

# --- Hydra ---
/multirun/
.hydra/

# --- OS ---
*.log
*.tmp
*.bak
